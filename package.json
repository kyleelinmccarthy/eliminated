{
  "name": "eliminated",
  "version": "1.0.0",
  "private": true,
  "description": "Eliminated — a deadly playground party game. Squid Game's children's games meet Boomerang Fu's silly chaos.",
  "type": "module",
  "scripts": {
    "predev": "lsof -ti:3000 | xargs -r kill 2>/dev/null || true",
    "dev": "tsx watch server.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "migrate:auth": "tsx scripts/migrate-auth.ts",
    "smoke": "node scripts/smoke.mjs",
    "smoke:all": "node scripts/smoke-all.mjs",
    "smoke:survivor": "node scripts/verify-single-survivor.mjs",
    "sim:feedback": "tsx scripts/sim-feedback.mts",
    "sim:chutes": "tsx scripts/sim-chutes.mts",
    "sim:tug": "tsx scripts/sim-tug.mts",
    "sim:tag": "tsx scripts/sim-tag.mts",
    "sim:mingle": "tsx scripts/sim-mingle.mts",
    "sim:musicalchairs": "tsx scripts/sim-musicalchairs.mts",
    "sim:present": "tsx scripts/sim-present.mts",
    "sim:feedback-form": "tsx scripts/sim-feedback-form.mts",
    "sim:betting": "tsx scripts/sim-betting.mts",
    "sim:accessories": "tsx scripts/sim-accessories.mts",
    "sim:accessory-draw": "tsx scripts/sim-accessory-draw.mts",
    "test": "npm run typecheck && npm run sim:tug && npm run sim:tag && npm run sim:mingle && npm run sim:musicalchairs && npm run sim:present && npm run sim:chutes && npm run sim:betting && npm run sim:accessories && npm run sim:accessory-draw && npm run sim:feedback-form && npm run sim:feedback"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@libsql/kysely-libsql": "^0.4.1",
    "better-auth": "1.6.14",
    "cross-env": "^7.0.3",
    "kysely": "^0.28.17",
    "next": "^15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^6.12.4",
    "tsx": "^4.19.2",
    "ws": "^8.18.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3"
  }
}
