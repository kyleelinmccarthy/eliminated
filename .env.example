# Eliminated — environment configuration

# Port the combined Next.js + WebSocket server listens on (default 3000)
PORT=3000

# --- Persistence (optional) ---
# By default the game persists profiles, currency, and the leaderboard to a
# local SQLite file at ./data/eliminated.db (created automatically).
# To use Turso instead, set these:
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-token

# --- Client -> server websocket URL (optional) ---
# Leave unset for single-service deploys (Railway) — the client connects to the
# same origin. For a split deploy (UI on Vercel, game server on Railway), set
# this to your game server, e.g. wss://eliminated-server.up.railway.app/ws
# NEXT_PUBLIC_WS_URL=
