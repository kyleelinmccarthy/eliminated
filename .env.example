# Eliminated — environment configuration

# Port the combined Next.js + WebSocket server listens on (default 3000)
PORT=3000

# --- Persistence (optional) ---
# By default the game persists profiles, currency, and the leaderboard to a
# local SQLite file at ./data/eliminated.db (created automatically).
# To use Turso instead, set these:
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-token

# --- Client -> server websocket URL (optional) ---
# Leave unset for single-service deploys (Railway) — the client connects to the
# same origin. For a split deploy (UI on Vercel, game server on Railway), set
# this to your game server, e.g. wss://eliminated-server.up.railway.app/ws
# NEXT_PUBLIC_WS_URL=

# --- Optional accounts (Better Auth) ---
# Guests need NONE of this. These only enable optional sign-in to save/sync
# progress across devices. The auth tables live in the same DB as profiles.
#
# Signing secret — REQUIRED for accounts to work. Generate with:
#   openssl rand -base64 32
# BETTER_AUTH_SECRET=
#
# Public base URL of this server; must match the browser origin exactly.
# BETTER_AUTH_URL=http://localhost:3000
#
# Google OAuth (Cloud Console → Credentials → OAuth client ID → "Web application").
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
# Leave unset to hide the "Continue with Google" button.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# Resend — transactional email (verification, password reset, anything else).
# Leave RESEND_API_KEY unset in dev to log emails to the console instead of sending.
# EMAIL_FROM must be a sender on a domain you've verified in Resend.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Eliminated <support@eliminatedgame.com>
